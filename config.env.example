# ──────────────────────────────────────────────
# SpendingAnalyser LLM 配置文件
# ──────────────────────────────────────────────
# 使用前请将本文件复制为 config.env 并填写实际值：
#   cp config.env.example config.env
#
# 本文件是模板，可以提交到 Git。
# config.env 包含真实密钥，已被 .gitignore 排除。

# API Key（从模型服务商控制台获取）
LLM_API_KEY=在此填写你的API密钥

# API Base URL（兼容 Anthropic 格式的接口地址）
# 小米 MiMo:   https://api.xiaomimimo.com/anthropic
# MiniMax:     https://api.minimaxi.com/anthropic
LLM_BASE_URL=https://api.xiaomimimo.com/anthropic

# 模型名称
# 小米 MiMo:   mimo-v2.5-pro
# MiniMax:     MiniMax-M2.5
LLM_MODEL=mimo-v2.5-pro
